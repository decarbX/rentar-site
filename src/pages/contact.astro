---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact Sales — Rentar Fuel Catalyst | Rentar"
  description="Contact the Rentar sales team to discuss fuel catalyst deployment, request a demo, verify a reseller, or explore becoming an authorized distributor."
>
  <section class="hero" style="min-height:40vh;">
    <div class="hero-content">
      <p class="hero-tag">Get in touch</p>
      <h1 style="font-size:2.6rem;">Contact Rentar</h1>
      <p>Talk to our team about deploying the Rentar Fuel Catalyst, scheduling a demo, verifying a reseller, or becoming an authorized distributor.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:48px; max-width:1000px; margin:0 auto;">
        <div>
          <p class="section-label">Sales & Inquiries</p>
          <h2 class="section-title" style="font-size:1.8rem;">Contact our team</h2>
          <div style="margin:24px 0;">
            <p style="font-weight:600; color:var(--navy); margin-bottom:4px;">Email</p>
            <p><a href="mailto:info@rentar.com" style="color:var(--orange); text-decoration:none;">info@rentar.com</a></p>
          </div>
          <div style="margin:24px 0;">
            <p style="font-weight:600; color:var(--navy); margin-bottom:4px;">Headquarters</p>
            <p style="color:var(--gray-text);">Rentar Environmental Solutions, Inc.<br>515 N. Flagler Drive, Suite 350<br>West Palm Beach, FL 33401 USA</p>
          </div>
          <div style="margin:24px 0;">
            <p style="font-weight:600; color:var(--navy); margin-bottom:4px;">Verify a Reseller</p>
            <p style="color:var(--gray-text); margin-bottom:12px;">Confirm your supplier is currently authorized by Rentar before purchasing.</p>
            <a href="/downloads/Rentar_Verification_Advisory_Professional.pdf" target="_blank" rel="noopener" class="btn btn-outline" style="display:inline-block;">Verify Reseller (PDF)</a>
          </div>
        </div>
        <div>
          <p class="section-label">What to expect</p>
          <h2 class="section-title" style="font-size:1.8rem;">Our process</h2>
          <div class="manifesto-block">
            <p style="color:var(--gray-text); line-height:1.8;">When you contact Rentar, our engineering team will:</p>
            <ol style="color:var(--gray-text); line-height:2; padding-left:20px;">
              <li>Understand your equipment fleet, fuel types, and operating conditions</li>
              <li>Model expected fuel savings based on your specific application</li>
              <li>Design a proof-of-concept deployment tailored to your operations</li>
              <li>Present a validation plan with measured before/after results</li>
              <li>Support deployment, monitoring, and ongoing optimization</li>
            </ol>
            <p style="margin-top:20px; color:var(--gray-text);">All Rentar products are sold exclusively through Rentar or authorized distributors. We respond to all inquiries within one business day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--navy); text-align:center;">
    <div class="container-narrow">
      <p class="section-label" style="color:rgba(255,255,255,0.5);">Become a distributor</p>
      <h2 class="section-title" style="color:var(--white);">Interested in becoming an authorized distributor?</h2>
      <p class="section-text" style="color:rgba(255,255,255,0.7); margin-bottom:40px;">Rentar selectively partners with qualified organizations serving industrial markets worldwide. Contact us to discuss partnership opportunities.</p>
      <a href="mailto:info@rentar.com" class="btn btn-primary">Contact us</a>
    </div>
  </section>
</BaseLayout>
