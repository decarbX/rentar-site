---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Locations — Rentar Environmental Solutions | Rentar"
  description="Rentar Environmental Solutions headquarters and office locations."
>
  <section class="hero" style="min-height:35vh;">
    <div class="hero-content">
      <p class="hero-tag">Global Presence</p>
      <h1 style="font-size:2.6rem;">Locations</h1>
      <p>Rentar Environmental Solutions is headquartered in West Palm Beach, Florida, with deployments and authorized distribution partners across more than 20 countries worldwide.</p>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <p class="section-label">Headquarters</p>
      <h2 class="section-title">West Palm Beach, Florida</h2>
      <div class="manifesto-block">
        <p>Rentar Environmental Solutions, Inc.<br>515 N. Flagler Drive, Suite 350<br>West Palm Beach, FL 33401 USA</p>
        <p style="margin-top:16px;">Email: <a href="mailto:info@rentar.com" style="color:var(--orange);">info@rentar.com</a></p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container-narrow">
      <p class="section-label">Authorized Distribution</p>
      <h2 class="section-title">Global partner network</h2>
      <div class="manifesto-block">
        <p>Rentar products are deployed and supported through authorized distribution partners across more than 20 countries. For information about a distributor in your region, <a href="/contact" style="color:var(--orange);">contact our sales team</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
