---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Terms of Use — Rentar Environmental Solutions | Rentar"
  description="Terms of Use for the Rentar Environmental Solutions website at rentar.net."
>
  <section class="hero" style="min-height:25vh;">
    <div class="hero-content">
      <p class="hero-tag">Legal</p>
      <h1 style="font-size:2.2rem;">Terms of Use</h1>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <div class="manifesto-block">
        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;">Acceptance of Terms</p>
        <p>By accessing and using the Rentar Environmental Solutions, Inc. ("Rentar") website at rentar.net (the "Site"), you agree to these Terms of Use. If you do not agree, please do not use the Site.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Intellectual Property</p>
        <p>All content on this Site, including text, graphics, logos, images, downloadable documents, and software, is the property of Rentar or its content suppliers and is protected by United States and international copyright, trademark, and intellectual property laws. The Rentar name, logo, and product names are trademarks of Rentar Environmental Solutions, Inc.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Use of Site</p>
        <p>You may view and download content from the Site for your personal, non-commercial use. You may not modify, reproduce, distribute, or commercially exploit any content without Rentar's express written permission.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Disclaimer</p>
        <p>The Site and its content are provided "as is" without warranty of any kind. Rentar makes no representations about the suitability, reliability, or accuracy of the information on the Site. Product performance results are application-specific and not guaranteed.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Limitation of Liability</p>
        <p>Rentar shall not be liable for any damages arising from the use or inability to use the Site or its content.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Contact</p>
        <p>For questions about these terms, contact <a href="mailto:info@rentar.com" style="color:var(--orange);">info@rentar.com</a>.</p>

        <p style="margin-top:32px; font-size:0.9rem; color:var(--gray-mid);">Last updated: July 2026</p>
      </div>
    </div>
  </section>
</BaseLayout>
