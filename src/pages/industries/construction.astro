    "Hydraulic Excavators",
    "Bulldozers & Track Dozers",
    "Wheel Loaders",
    "Motor Graders",
    "Mobile Cranes",
    "Concrete Pumps & Mixers"
  ]}
  results={[
    { label: "Heavy construction equipment efficiency gain", value: "5–12%" },
    { label: "High-idle and PTO-heavy cycles", value: "Higher savings" },
    { label: "Engine compatibility", value: "1M+ configurations" }
  ]}
/>
