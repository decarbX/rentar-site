  heroTitle="Waste Management"
  heroSubtitle="Reduce fuel consumption across collection trucks, landfill equipment, transfer station loaders, and waste processing machinery."
  applications={[
    "Front-Load & Rear-Load Collection Trucks",
    "Roll-Off & Hook-Lift Trucks",
    "Landfill Compactors & Dozers",
    "Transfer Station Loaders",
    "Recycling Facility Equipment",
    "Street Sweepers"
  ]}
  results={[
    { label: "Collection truck fuel efficiency gain", value: "5–12%" },
    { label: "Stop-and-go duty cycle efficiency", value: "Higher PTO savings" },
    { label: "Engine compatibility", value: "1M+ configurations" }
  ]}
/>
