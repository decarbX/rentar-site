  heroTitle="Rail"
  heroSubtitle="Improve fuel efficiency across diesel-electric locomotives, rail maintenance equipment, and switchyard operations."
  applications={[
    "Diesel-Electric Locomotives",
    "Switchyard & Shunting Engines",
    "Rail Maintenance Vehicles",
    "Track Inspection Trucks",
    "Railcar Movers",
    "Passenger Rail Diesel Units"
  ]}
  results={[
    { label: "Diesel locomotive fuel efficiency gain", value: "3–8%" },
    { label: "Switchyard & low-speed operations", value: "Higher efficiency" },
    { label: "Engine compatibility", value: "1M+ configurations" }
  ]}
/>
