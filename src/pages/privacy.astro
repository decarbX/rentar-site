---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy — Rentar Environmental Solutions | Rentar"
  description="Privacy Policy for Rentar Environmental Solutions, Inc. — how we collect, use, and protect your information."
>
  <section class="hero" style="min-height:25vh;">
    <div class="hero-content">
      <p class="hero-tag">Legal</p>
      <h1 style="font-size:2.2rem;">Privacy Policy</h1>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <div class="manifesto-block">
        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;">Information We Collect</p>
        <p>Rentar Environmental Solutions, Inc. ("Rentar," "we," "us") collects information you provide when you contact us, including your name, email address, company name, phone number, and the content of your inquiry. We also collect standard web server log information including IP address, browser type, referring pages, and visit timestamps.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">How We Use Information</p>
        <p>We use the information we collect to respond to your inquiries, provide information about our products and services, improve our website, and comply with legal obligations. We do not sell, rent, or trade your personal information to third parties.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Data Security</p>
        <p>We implement reasonable technical and organizational measures to protect your information against unauthorized access, alteration, disclosure, or destruction.</p>

        <p class="highlight-label" style="font-weight:600;color:var(--navy);font-size:1.15rem;margin-top:32px;">Contact</p>
        <p>For questions about this privacy policy, contact us at <a href="mailto:info@rentar.com" style="color:var(--orange);">info@rentar.com</a> or at our headquarters address: Rentar Environmental Solutions, Inc., 515 N. Flagler Drive, Suite 350, West Palm Beach, FL 33401 USA.</p>

        <p style="margin-top:32px; font-size:0.9rem; color:var(--gray-mid);">Last updated: July 2026</p>
      </div>
    </div>
  </section>
</BaseLayout>
