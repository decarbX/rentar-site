<!-- ====== VALIDATION ====== -->
<section class="section validation-section" id="results">
  <div class="container">
    <p class="section-label">Independent Validation</p>
    <h2 class="section-title" style="margin-bottom:40px;">Field-verified performance</h2>

    <div class="validation-panels">
      <!-- VALE — Hero Panel -->
      <div class="val-panel val-panel--large">
        <div class="val-header">
          <p class="val-label">Independent Laboratory Verification</p>
          <p class="val-title">VALE Itabira Complex</p>
          <p class="val-subtitle">Verified GHG emissions reduction · Brazil</p>
        </div>
        <div class="val-animation">
          <iframe src="/images/vale_ghg_reduction" title="VALE Itabira Complex — Verified GHG Reduction" loading="lazy"></iframe>
        </div>
        <div class="val-specs">
          <div class="val-spec">
            <p class="val-spec-label">Test Platform</p>
            <p class="val-spec-value">CAT 793F OHT</p>
          </div>
          <div class="val-spec">
            <p class="val-spec-label">Engine</p>
            <p class="val-spec-value">CAT 175-16</p>
          </div>
          <div class="val-spec">
            <p class="val-spec-label">Verification</p>
            <p class="val-spec-value">Before / After</p>
          </div>
          <div class="val-spec">
            <p class="val-spec-label">Laboratory</p>
            <p class="val-spec-value">Third Party</p>
          </div>
        </div>
        <div class="val-body">
          <p class="val-description">The Rentar Fuel Catalyst was successfully validated at the VALE Itabira Complex in Brazil with verified reductions in GHG emissions on two Caterpillar 793F Off Highway Trucks. Emissions testing performed by an independent third-party laboratory.</p>
        </div>
        <div class="val-ribbon">
          <span class="val-badge val-badge--active">Verified</span>
          <span class="val-badge val-badge--active">Laboratory Tested</span>
          <span class="val-badge val-badge--active">Field Validated</span>
          <span class="val-badge">Third Party</span>
          <span class="val-badge">Patent Protected</span>
        </div>
        <a href="/results/vale-itabira" class="val-link">View verification details</a>
      </div>

      <!-- ADANI — Commercial Deployment -->
      <div class="val-panel val-panel--small">
        <div class="val-header">
          <p class="val-label">Commercial Fleet Validation</p>
          <p class="val-title">ADANI (APSEZ)</p>
          <p class="val-subtitle">Marine fuel efficiency · Indian waters</p>
        </div>
        <div class="val-animation">
          <iframe src="/images/marine_fuel_reduction" title="Adani India Marine — Fuel Efficiency" loading="lazy"></iframe>
        </div>
        <div class="val-specs">
          <div class="val-spec">
            <p class="val-spec-label">Application</p>
            <p class="val-spec-value">Marine Tugboats</p>
          </div>
          <div class="val-spec">
            <p class="val-spec-label">Result</p>
            <p class="val-spec-value">~5% Fuel Efficiency</p>
          </div>
          <div class="val-spec">
            <p class="val-spec-label">Location</p>
            <p class="val-spec-value">India</p>
          </div>
          <div class="val-spec">
            <p class="val-spec-label">Status</p>
            <p class="val-spec-value">Demonstrated</p>
          </div>
        </div>
        <div class="val-body">
          <p class="val-description">Fuel flow meters measured net fuel consumption on two tugboats with propulsion engines. Consistent fuel savings demonstrated across marine vessels operating in Indian waters.</p>
        </div>
        <div class="val-ribbon">
          <span class="val-badge val-badge--active">Marine</span>
          <span class="val-badge val-badge--active">Field Validated</span>
          <span class="val-badge">Patent Protected</span>
        </div>
        <a href="/results/adani-marine" class="val-link">View case study</a>
      </div>
    </div>

    <!-- Reference Documents -->
    <div class="val-reference-grid">
      <div class="val-ref-card">
        <p class="val-ref-label">Reference Document</p>
        <p class="val-ref-title">SITECH Reference</p>
        <p class="val-ref-text">Independent customer reference documentation describing the deployment and performance of the Rentar Fuel Catalyst.</p>
        <a href="/downloads/RENTAR-SITECH_Reference_Letter.pdf" target="_blank" rel="noopener" class="val-ref-btn">View Reference →</a>
      </div>
      <div class="val-ref-card">
        <p class="val-ref-label">Reference Document</p>
        <p class="val-ref-title">ADANI (APSEZ) Reference</p>
        <p class="val-ref-text">Independent customer reference documentation describing the deployment and operational experience with the Rentar Fuel Catalyst.</p>
        <a href="/downloads/RENTAR-ADANI_Reference_Letter.pdf" target="_blank" rel="noopener" class="val-ref-btn">View Reference →</a>
      </div>
    </div>
  </div>
</section>

<!-- ====== IP & DISTRIBUTION ====== -->
<section class="section section-light ip-section" id="ip">
  <div class="container-narrow">
    <p class="section-label">Intellectual Property &amp; Distribution</p>
    <h2 class="section-title">Protected Technology. Controlled Worldwide.</h2>
    <div class="manifesto-block">
      <p>The Rentar Fuel Catalyst represents more than two decades of engineering, field deployment, and intellectual property development. The technology is protected through an international patent portfolio and associated proprietary manufacturing processes developed for heavy duty diesel applications.</p>
      <p>Rentar<sup style="font-size:0.55em;">®</sup> Environmental Solutions is the exclusive worldwide commercial rights holder for the Rentar Fuel Catalyst, including the exclusive authority to manufacture, market, distribute, license, sell, and deploy the technology throughout industrial and commercial markets.</p>
      <p>Every genuine Rentar Fuel Catalyst originates through Rentar or an authorized distribution partner operating under Rentar's written approval and ongoing commercial supervision.</p>

      <p class="highlight-label">Intellectual Property</p>
      <p>The Rentar Fuel Catalyst is supported by an international portfolio of patents covering the technology and its commercial application. Rentar's intellectual property includes:</p>
      <ul style="list-style:none; padding-left:0; margin-bottom:24px;">
        <li style="padding:4px 0;">International patent portfolio</li>
        <li style="padding:4px 0;">Proprietary catalyst formulation</li>
        <li style="padding:4px 0;">Manufacturing processes</li>
        <li style="padding:4px 0;">Commercial licensing rights</li>
        <li style="padding:4px 0;">Application engineering</li>
        <li style="padding:4px 0;">Product branding and trademarks</li>
        <li style="padding:4px 0;">Technical documentation and deployment methodologies</li>
      </ul>
      <p>Our intellectual property has been developed through more than twenty years of commercial deployment across mining, marine, transportation, agriculture, power generation, and industrial operations.</p>

      <p class="highlight-label">Exclusive Commercial Rights</p>
      <p>Rentar is the exclusive organization authorized to commercially exploit the Rentar Fuel Catalyst worldwide. These exclusive rights include the authority to manufacture, market, sell, distribute, license, deploy, support, and authorize distributors for the Rentar Fuel Catalyst and related commercial applications.</p>

      <p class="highlight-label">Authorized Distribution</p>
      <p>To protect customers, product integrity, and technical support, Rentar products are available only through Rentar or officially authorized distributors. Authorized distributors operate under Rentar's written authorization, commercial supervision, product training, quality standards, branding requirements, and technical support program.</p>

      <p class="highlight-label">Verify Your Supplier</p>
      <p>If you are considering the purchase of a Rentar Fuel Catalyst, we encourage you to verify that your supplier is currently authorized by Rentar. Purchasing through an authorized distributor ensures genuine Rentar products, factory backed technical support, current product specifications, warranty eligibility, access to engineering assistance, and ongoing customer support.</p>

      <p class="highlight-label">Unauthorized Sales Notice</p>
      <p>No individual, company, reseller, manufacturer, representative, or third party is authorized to manufacture, market, distribute, license, sell, or commercialize the Rentar Fuel Catalyst unless expressly authorized in writing by Rentar<sup style="font-size:0.55em;">®</sup> Environmental Solutions. Claims of authorization should be independently verified with Rentar prior to purchase.</p>

      <!-- Verify Reseller Callout Panel -->
      <div style="background:var(--white); border:1px solid #e0e0e0; border-radius:8px; padding:32px; margin:32px 0; box-shadow:0 2px 12px rgba(0,0,0,0.06);">
        <h3 style="font-size:1.3rem; font-weight:600; color:var(--navy); margin-bottom:12px;">Verify Your Reseller</h3>
        <p style="font-size:1rem; color:var(--gray-text); margin-bottom:16px;">Before purchasing a Rentar Fuel Catalyst, confirm that your supplier is currently authorized by Rentar<sup style="font-size:0.55em;">®</sup> Environmental Solutions.</p>
        <p style="font-size:0.95rem; color:var(--gray-text); margin-bottom:16px;">Purchasing through an authorized source helps ensure:</p>
        <ul style="list-style:none; padding-left:0; margin-bottom:24px;">
          <li style="padding:4px 0; color:var(--gray-text);">&#10003; Genuine Rentar products</li>
          <li style="padding:4px 0; color:var(--gray-text);">&#10003; Factory backed technical support</li>
          <li style="padding:4px 0; color:var(--gray-text);">&#10003; Current technical documentation</li>
          <li style="padding:4px 0; color:var(--gray-text);">&#10003; Warranty eligibility where applicable</li>
          <li style="padding:4px 0; color:var(--gray-text);">&#10003; Access to Rentar engineering resources</li>
        </ul>
        <a href="/downloads/Rentar_Verification_Advisory_Professional.pdf" target="_blank" rel="noopener" class="btn btn-primary" aria-label="Verify Authorized Rentar Reseller PDF" style="display:inline-block;">Verify Reseller</a>
        <p style="margin-top:20px; font-size:0.85rem; color:var(--gray-mid);">Questions? <a href="mailto:info@rentar.com" style="color:var(--orange);">info@rentar.com</a></p>
        <p style="margin-top:8px;"><a href="mailto:info@rentar.com?subject=Unauthorized%20Rentar%20Reseller%20Report" style="font-size:0.85rem; color:var(--navy); text-decoration:underline;">Report Unauthorized Representation</a></p>
      </div>

      <p class="highlight-label">Become an Authorized Distributor</p>
      <p>Rentar selectively partners with qualified organizations serving industrial markets worldwide. Authorized partners receive technical training, sales support, marketing resources, territory development, engineering assistance, and factory support. Interested in becoming an authorized distributor? Contact our commercial team.</p>
    </div>

    <!-- Icon Cards -->
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-top:48px;">
      <div style="background:var(--navy); padding:24px 20px; border-radius:2px; text-align:center;">
