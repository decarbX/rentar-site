    <p class="section-label">Industries &amp; Applications</p>
    <h2 class="section-title" style="margin-bottom:40px;">Where we work</h2>
    <div class="industry-grid">
      <a href="/industries/mining" class="industry-card"><svg class="industry-icon" viewBox="0 0 32 32" fill="none" stroke="white" stroke-width="1.5"><path d="M4 28V12l12-8 12 8v16"/><circle cx="16" cy="20" r="3"/></svg><span>Mining</span></a>
