        <div style="font-size:0.75rem; color:rgba(255,255,255,0.45); margin-top:4px;">Factory approved global partner network</div>
      </div>
      <div style="background:var(--navy); padding:24px 20px; border-radius:2px; text-align:center;">
        <div style="font-size:1.2rem; font-weight:500; color:var(--white); margin-bottom:8px;">Protected</div>
        <div style="font-size:0.85rem; color:rgba(255,255,255,0.65);">Brand</div>
        <div style="font-size:0.75rem; color:rgba(255,255,255,0.45); margin-top:4px;">Authentic products backed by Rentar</div>
